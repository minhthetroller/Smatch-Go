# ── General ───────────────────────────────────────────────────────────────────
app_name    = "smatch"
environment = "staging"
azure_region = "southeastasia"

# ── Networking ────────────────────────────────────────────────────────────────
# Override defaults if needed

# ── Compute / VMSS ────────────────────────────────────────────────────────────
vmss_instance_type = "Standard_B2s"
vmss_admin_username = "smatch"
# vmss_ssh_public_key = "ssh-rsa AAAA..."  # required — set in terraform.tfvars

backend_asg_desired_capacity = 2

# ── Database ──────────────────────────────────────────────────────────────────
db_username = "psqladmin"
# db_password = ""  # required — set in terraform.tfvars

# ── Redis (Azure Managed Redis) ───────────────────────────────────────────────
managed_redis_sku = "Balanced_B0"

# ── Storage ───────────────────────────────────────────────────────────────────

# ── Container Registry ────────────────────────────────────────────────────────
# acr_name = "smatchregistry"  # globally unique, alphanumeric only

# ── DNS / TLS ─────────────────────────────────────────────────────────────────
# domain_name       = "example.com"
# api_subdomain     = "api"
# create_dns        = false
# letsencrypt_email = "admin@example.com"  # required for automatic cert issuance

# ── Application Config ────────────────────────────────────────────────────────
# zalopay_app_id   = ""
# zalopay_key1     = ""
# zalopay_key2     = ""
# zalopay_endpoint = "https://sb-openapi.zalopay.vn"
# zalopay_callback_url = ""
# admin_secret     = ""
