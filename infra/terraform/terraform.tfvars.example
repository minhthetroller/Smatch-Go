# ── terraform.tfvars.example ──────────────────────────────────────────────────
# Copy to terraform.tfvars and fill in your values for real AWS deployment.
# DO NOT commit terraform.tfvars to version control.

# ── AWS ──────────────────────────────────────────────────────────────────────
aws_region  = "ap-southeast-1"
aws_profile = "default"        # AWS CLI profile from ~/.aws/credentials
environment = "staging"        # staging | production

# Leave empty for real AWS (LocalStack sets this to "http://localstack:4566")
aws_endpoint = ""

# ── Networking ───────────────────────────────────────────────────────────────
# Three subnet tiers — all lists must match the number of availability_zones.
#   public             → ALB (internet-facing)
#   private_app        → ASG / EC2 instances (egress via NAT)
#   private (data)     → RDS + ElastiCache (no internet access)
availability_zones       = ["ap-southeast-1a", "ap-southeast-1b"]
public_subnet_cidrs      = ["10.0.1.0/24", "10.0.2.0/24"]
private_app_subnet_cidrs = ["10.0.3.0/24", "10.0.4.0/24"]
private_subnet_cidrs     = ["10.0.5.0/24", "10.0.6.0/24"]

# ── EC2 / ASG ────────────────────────────────────────────────────────────────
# Use Amazon Linux 2023 AMI for your region:
#   aws ec2 describe-images --owners amazon \
#     --filters "Name=name,Values=al2023-ami-2023*-x86_64" \
#     --query 'Images | sort_by(@, &CreationDate) | [-1].ImageId' --output text
ami_id        = "ami-0abcdef1234567890"
instance_type = "t3.small"

# Optional: use these only when the admin image architecture differs from the
# backend image architecture. For example, a linux/arm64 admin image can run on
# a Graviton instance with an AL2023 arm64 AMI.
admin_ami_id        = ""
admin_instance_type = ""

asg_min_size         = 1
asg_max_size         = 3
asg_desired_capacity = 2
asg_cpu_target_percent = 60
asg_request_count_target_per_minute = 100

# ── ECR ──────────────────────────────────────────────────────────────────────
# Create ECR repo first, then push your Docker image:
#   aws ecr create-repository --repository-name smatch-backend
#   ECR_URL=$(aws ecr describe-repositories --repository-names smatch-backend \
#     --query 'repositories[0].repositoryUri' --output text)
ecr_repo_url = "123456789012.dkr.ecr.ap-southeast-1.amazonaws.com/smatch-backend"

# ── Database ─────────────────────────────────────────────────────────────────
db_name     = "smatch"
db_username = "postgres"
db_password = "CHANGE_ME_strong_password_here"  # minimum 12 characters

# ── Firebase ─────────────────────────────────────────────────────────────────
firebase_credentials_file = "/app/smatch-badminton-firebase-adminsdk-fbsvc-fb65abab30.json"

# ── ZaloPay ──────────────────────────────────────────────────────────────────
zalopay_app_id       = "2554"
zalopay_key1         = ""
zalopay_key2         = ""
zalopay_endpoint     = "https://sb-openapi.zalopay.vn"  # sandbox
zalopay_callback_url = "https://your-domain.com/api/payments/callback"

# ── Tile Server ──────────────────────────────────────────────────────────────
# The API ALB routes /api/map-tiles/* directly to the Fargate pg_tileserv service.
tile_server_url = "http://localhost:7800"

tileserv_desired_count    = 2
tileserv_task_cpu         = 512
tileserv_task_memory      = 1024
tileserv_image_url        = "pramsey/pg_tileserv:latest"
tileserv_nginx_image_url  = "nginx:1.27-alpine"
tileserv_port             = 7800
tileserv_nginx_port       = 80

# ── Admin ────────────────────────────────────────────────────────────────────
admin_domain_name = "admin-sb.online"
admin_secret      = ""
redis_password    = "" # Set a strong password for ElastiCache AUTH in production
load_test_stress_enabled = false # true only while running controlled DLT CPU tests

# ── Admin web / CloudFront ───────────────────────────────────────────────────
# Leave empty to derive smatch-<env>-admin-web-<account-id>.
web_bucket_name          = ""
web_bucket_force_destroy = true

# ── Observability / incident response ───────────────────────────────────────
incident_email                  = "nguyentuanminh1105@gmail.com"
log_retention_days              = 14
cpu_alarm_threshold             = 70
cpu_alarm_period_seconds        = 60
cpu_alarm_evaluation_periods    = 2
lambda_log_lookback_minutes     = 15
