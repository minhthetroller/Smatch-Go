# ─────────────────────────────────────────────────────────────────────────────
# Smatch Badminton Backend — Go
# Copy this file to .env and fill in the values before running the server.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development          # development | production

# ── PostgreSQL ───────────────────────────────────────────────────────────────
# Full connection string including the PostGIS-enabled database.
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/smatch?sslmode=disable

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=               # leave blank if no auth
REDIS_TLS_ENABLED=false       # true in production (e.g. Redis Cloud, Upstash)

# ── Firebase Admin SDK ───────────────────────────────────────────────────────
# Path to the service-account JSON downloaded from the Firebase console:
#   Firebase Console → Project Settings → Service Accounts → Generate new private key
# Path is relative to the working directory of the binary (i.e. smatch-backend-go/).
# The default points one level up to the existing key in the project root.
FIREBASE_CREDENTIALS_FILE=../smatch-badminton-firebase-adminsdk-fbsvc-fb65abab30.json

# ── ZaloPay ──────────────────────────────────────────────────────────────────
ZALOPAY_APP_ID=               # numeric app ID from ZaloPay dashboard
ZALOPAY_KEY1=                 # HMAC key for creating order MAC
ZALOPAY_KEY2=                 # HMAC key for verifying callback MAC
ZALOPAY_ENDPOINT=https://sb-openapi.zalopay.vn   # sandbox; use https://openapi.zalopay.vn in prod
ZALOPAY_CALLBACK_URL=         # public HTTPS URL ZaloPay will POST to, e.g. https://api.example.com/api/payments/callback

# ── AWS S3 ───────────────────────────────────────────────────────────────────
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=            # IAM access key with s3:PutObject / s3:DeleteObject on the two buckets
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_PROFILE=smatch-profiles       # bucket for user profile photos
AWS_S3_BUCKET_MATCHES=smatch-matches        # bucket for match images
AWS_S3_BUCKET_BUSINESS_DOCS=smatch-business-docs  # bucket for court owner business documents
# AWS_ENDPOINT=http://localhost:4566        # uncomment for LocalStack in development

# ── Map Tile Server ───────────────────────────────────────────────────────────
# pg_tileserv / Martin / t-rex endpoint proxied at GET /api/map-tiles/:z/:x/:y.pbf
TILE_SERVER_URL=http://localhost:7800

# ── Payments ─────────────────────────────────────────────────────────────────
# Payment transactions are valid for a hard-coded 300 seconds.
# This ticket only authorizes the initial websocket subscription and is capped
# by the payment's remaining validity.
PAYMENT_WS_TICKET_TTL_SECONDS=60

# ── Admin ─────────────────────────────────────────────────────────────────────
# Static secret for admin-only endpoints when Firebase custom claims are not set.
# Pass as the X-Admin-Secret header. Leave blank to disable header-based admin auth.
ADMIN_SECRET=
ADMIN_PORT=3001
ADMIN_WEB_ORIGIN=https://admin-sb.online   # CORS origin for the admin/court-owner web app
